
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>おうち在庫アプリ</title>

<style>
body {
  margin: 0;
  font-family: "Segoe UI", sans-serif;
  background: linear-gradient(135deg, #ffe6f0, #e3f1ff);
  padding: 12px;
}

/* ヘッダー */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
h1 { font-size: 20px; }
#updated { font-size: 12px; }

/* タブ */
nav {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}
nav button {
  flex: 1;
  padding: 10px;
  border-radius: 20px;
  border: none;
  font-size: 14px;
  background: #fff;
}
nav button.active {
  background: #ff7eb6;
  color: white;
}

/* パネル */
.panel { display: none; }
.panel.active { display: block; }

/* カード */
.section-title {
  font-weight: bold;
  margin: 12px 0 6px;
}
.card {
  background: white;
  border-radius: 16px;
  padding: 10px;
  margin-bottom: 8px;
  display: flex;
  gap: 6px;
  align-items: center;
}
.name { flex: 1; }

/* 入力系 */
select, button, textarea, input {
  border-radius: 10px;
  border: none;
  padding: 6px;
  font-size: 14px;
}
.delete { background: #ddd; }
textarea {
  width: 100%;
  min-height: 80px;
}
</style>
</head>

<body>

<header>
  <h1>🧺 おうち在庫</h1>
  <div id="updated">更新：</div>
</header>

<nav>
  <button id="btnStock" class="active" onclick="switchView('stock')">在庫</button>
  <button id="btnBuy" onclick="switchView('buy')">買い物</button>
</nav>

<!-- 在庫画面 -->
<div id="stock" class="panel active">

  <!-- 品目追加 -->
  <div class="card">
    <input id="newName" placeholder="品目名" style="flex:1">
    <select id="newCat">
      <option value="food">食材</option>
      <option value="seasoning">調味料</option>
      <option value="supply">消耗品</option>
    </select>
    <button onclick="addItem()">追加</button>
  </div>

  <div class="section-title">🍚 食材</div>
  <div id="food"></div>

  <div class="section-title">🧂 調味料</div>
  <div id="seasoning"></div>

  <div class="section-title">🧻 消耗品</div>
  <div id="supply"></div>
</div>

<!-- 買い物画面 -->
<div id="buy" class="panel">
  <div id="shopping"></div>
</div>

<!-- メモ -->
<div class="card">
  <div style="flex:1">
    <strong>📝 メモ</strong>
    <textarea id="memo" placeholder="家族への伝言、買い物メモなど"></textarea>
  </div>
</div>

<script>
/* ===== 設定 ===== */
const API_URL = "https://script.google.com/macros/s/AKfycbwUtO9udyk8E0AyI1KGTO5pXCLUm_-gFU5CU4gG0K61mQeqShIhgq2U7kkrB5gyWnMBYw/exec";

/* ===== 定数 ===== */
const STATUS = ["5","4","3","2","1","残りわずか","在庫なし"];

/* ===== データ ===== */
let items = { food:[], seasoning:[], supply:[] };

/* ===== 共通 ===== */
function updateTime() {
  document.getElementById("updated").textContent =
    "更新：" + new Date().toLocaleString();
}

function switchView(v) {
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
  document.querySelectorAll("nav button").forEach(b=>b.classList.remove("active"));
  document.getElementById(v).classList.add("active");
  document.getElementById("btn"+(v==="stock"?"Stock":"Buy")).classList.add("active");
}

/* ===== 表示 ===== */
function renderCategory(id, list) {
  const area = document.getElementById(id);
  area.innerHTML = "";
  list.forEach((it,i)=>{
    const c=document.createElement("div");
    c.className="card";

    const n=document.createElement("div");
    n.className="name";
    n.textContent=it.name;

    const s=document.createElement("select");
    STATUS.forEach(st=>{
      const o=document.createElement("option");
      o.value=o.textContent=st;
      if(st===it.status) o.selected=true;
      s.appendChild(o);
    });
    s.onchange=()=>{ it.status=s.value; afterChange(); };

    const d=document.createElement("button");
    d.textContent="削除";
    d.className="delete";
    d.onclick=()=>{ list.splice(i,1); afterChange(); };

    c.append(n,s,d);
    area.appendChild(c);
  });
}

function renderShopping() {
  const buy=[];
  Object.values(items).flat().forEach(i=>{
    if(["残りわずか","在庫なし"].includes(i.status)) {
      buy.push(`${i.name}（${i.status}）`);
    }
  });
  const s=document.getElementById("shopping");
  s.innerHTML = buy.length
    ? buy.map(b=>`<div class="card">${b}</div>`).join("")
    : "買い物はありません 🎉";
}

function render() {
  renderCategory("food", items.food);
  renderCategory("seasoning", items.seasoning);
  renderCategory("supply", items.supply);
  renderShopping();
  updateTime();
}

/* ===== 追加 ===== */
function addItem() {
  const name=newName.value.trim();
  if(!name) return;
  items[newCat.value].push({name, status:"5"});
  newName.value="";
  afterChange();
}

/* ===== API ===== */
async function loadData(){
  const res = await fetch(API_URL);
  const data = await res.json();
  items = { food:data.food, seasoning:data.seasoning, supply:data.supply };
  memo.value = data.memo || "";
  render();
}

async function saveData(){
  await fetch(API_URL,{
    method:"POST",
    body: JSON.stringify({
      items,
      memo: memo.value
    })
  });
}

function afterChange(){
  render();
  saveData();
}

memo.oninput = afterChange;

/* 初期読み込み */
loadData();
</script>

</body>
</html>
``
